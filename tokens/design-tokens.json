{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "ระบบจองห้องประชุมมหาวิทยาลัย — Design Tokens (W3C DTCG format)",

  "color": {
    "brand": {
      "primary":        { "$type": "color", "$value": "#0d8a5f", "$description": "สีหลัก เขียว-เทอร์คอยสด ปุ่ม/ไฮไลต์/แถบ active" },
      "primary-strong": { "$type": "color", "$value": "#0a6b48", "$description": "เขียวเข้ม พื้นหลังเข้ม/แถบสรุป" },
      "accent":         { "$type": "color", "$value": "#2a8a86", "$description": "teal สว่าง สำหรับ eyebrow/ลิงก์" },
      "gradient":       { "$type": "color", "$value": "linear-gradient(135deg, #0d8a5f, #10b981)", "$description": "gradient สำหรับปุ่ม/ไฮไลต์พิเศษ" }
    },
    "neutral": {
      "0":   { "$type": "color", "$value": "#ffffff" },
      "50":  { "$type": "color", "$value": "#f6f9f9" },
      "100": { "$type": "color", "$value": "#eef2f2" },
      "150": { "$type": "color", "$value": "#e6eeee" },
      "200": { "$type": "color", "$value": "#e0e8e8" },
      "300": { "$type": "color", "$value": "#d3dede" },
      "400": { "$type": "color", "$value": "#b6c2c2" },
      "500": { "$type": "color", "$value": "#8a989a" },
      "600": { "$type": "color", "$value": "#5c6b6d" },
      "700": { "$type": "color", "$value": "#33474a" },
      "900": { "$type": "color", "$value": "#1b2b2d" }
    },
    "surface": {
      "page":   { "$type": "color", "$value": "{color.neutral.100}", "$description": "พื้นหลังหน้า" },
      "card":   { "$type": "color", "$value": "{color.neutral.0}",   "$description": "พื้นการ์ด" },
      "sunken": { "$type": "color", "$value": "#f7fafa", "$description": "กล่องย่อยในการ์ด เช่น approval chain" },
      "field":  { "$type": "color", "$value": "#fbfdfd", "$description": "พื้นช่องกรอก/ดรอปดาวน์" }
    },
    "text": {
      "primary":    { "$type": "color", "$value": "{color.neutral.900}" },
      "secondary":  { "$type": "color", "$value": "{color.neutral.600}" },
      "muted":      { "$type": "color", "$value": "{color.neutral.500}" },
      "on-primary": { "$type": "color", "$value": "#ffffff" }
    },
    "status": {
      "success": {
        "solid":   { "$type": "color", "$value": "#1f9d57", "$description": "ปุ่มอนุมัติ" },
        "accent":  { "$type": "color", "$value": "#3f9e74", "$description": "ขอบ/จุดสถานะ อนุมัติแล้ว" },
        "surface": { "$type": "color", "$value": "#e4f3ea" },
        "text":    { "$type": "color", "$value": "#1c6b4c" }
      },
      "warning": {
        "accent":  { "$type": "color", "$value": "#d9a93c", "$description": "รออนุมัติ/รอดำเนินการ" },
        "surface": { "$type": "color", "$value": "#fbf1da" },
        "text":    { "$type": "color", "$value": "#876217" },
        "border":  { "$type": "color", "$value": "#f0d27a", "$description": "ขอบเตือนการ์ดที่รอนานเกินกำหนด" }
      },
      "danger": {
        "solid":   { "$type": "color", "$value": "#d24b3e", "$description": "ปุ่มยืนยันปฏิเสธ" },
        "surface": { "$type": "color", "$value": "#fdecea", "$description": "พื้นปุ่มปฏิเสธ" },
        "text":    { "$type": "color", "$value": "#c43d2f" },
        "border":  { "$type": "color", "$value": "#f1c4bd" }
      }
    }
  },

  "font": {
    "family": {
      "base": { "$type": "fontFamily", "$value": ["Sarabun", "system-ui", "sans-serif"] },
      "mono": { "$type": "fontFamily", "$value": ["ui-monospace", "Menlo", "monospace"], "$description": "รหัสอ้างอิง" }
    },
    "weight": {
      "light":    { "$type": "fontWeight", "$value": 300 },
      "regular":  { "$type": "fontWeight", "$value": 400 },
      "medium":   { "$type": "fontWeight", "$value": 500 },
      "semibold": { "$type": "fontWeight", "$value": 600 },
      "bold":     { "$type": "fontWeight", "$value": 700 }
    },
    "size": {
      "xs":    { "$type": "dimension", "$value": "11px" },
      "sm":    { "$type": "dimension", "$value": "13px" },
      "base":  { "$type": "dimension", "$value": "14.5px" },
      "md":    { "$type": "dimension", "$value": "15px" },
      "lg":    { "$type": "dimension", "$value": "17px", "$description": "หัวข้อ section" },
      "xl":    { "$type": "dimension", "$value": "20px", "$description": "หัวข้อ dialog" },
      "2xl":   { "$type": "dimension", "$value": "25px", "$description": "หัวเรื่องหน้า" }
    }
  },

  "radius": {
    "sm":   { "$type": "dimension", "$value": "8px" },
    "md":   { "$type": "dimension", "$value": "10px" },
    "lg":   { "$type": "dimension", "$value": "14px", "$description": "การ์ด" },
    "xl":   { "$type": "dimension", "$value": "16px", "$description": "dialog/การ์ดใหญ่" },
    "pill": { "$type": "dimension", "$value": "999px", "$description": "badge/chip" }
  },

  "space": {
    "1": { "$type": "dimension", "$value": "4px" },
    "2": { "$type": "dimension", "$value": "8px" },
    "3": { "$type": "dimension", "$value": "12px" },
    "4": { "$type": "dimension", "$value": "16px" },
    "5": { "$type": "dimension", "$value": "20px" },
    "6": { "$type": "dimension", "$value": "24px" },
    "8": { "$type": "dimension", "$value": "32px" }
  },

  "shadow": {
    "card":  { "$type": "shadow", "$value": { "offsetX": "0", "offsetY": "3px",  "blur": "14px", "spread": "0", "color": "rgba(20,60,64,0.05)" } },
    "raised":{ "$type": "shadow", "$value": { "offsetX": "0", "offsetY": "8px",  "blur": "24px", "spread": "0", "color": "rgba(13,138,95,0.16)" } },
    "modal": { "$type": "shadow", "$value": { "offsetX": "0", "offsetY": "20px", "blur": "50px", "spread": "0", "color": "rgba(0,0,0,0.25)" } }
  }
}
