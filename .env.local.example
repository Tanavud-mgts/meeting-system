NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Test-only password login. Set to "false" in production — real users sign in
# with Google OAuth (@g.lpru.ac.th), configured in the Supabase Dashboard
# (Authentication > Providers > Google), not via a Next.js env var.
NEXT_PUBLIC_ENABLE_PASSWORD_LOGIN=true

# Shared secret for the Vercel Cron keep-alive endpoint (/api/keep-alive).
# Vercel sends it as `Authorization: Bearer ${CRON_SECRET}` on cron invocations.
CRON_SECRET=
